<section class="relative aspect-[4/5] overflow-hidden md:aspect-auto md:min-h-[calc(100vh-96px)]" aria-label="{{ client.restaurantName }}">
  <video id="hero-video" aria-hidden="true" width="1280" height="720" preload="none" loop muted playsinline poster="{{ client.hero.poster }}" data-mp4="{{ client.hero.video }}" data-webm="{{ client.hero.videoWebm }}" data-mp4-mobile="{{ client.hero.videoMobile }}" data-webm-mobile="{{ client.hero.videoMobileWebm }}" class="pointer-events-none absolute inset-0 h-full w-full object-cover" style="object-position:center 35%;"></video>
  <h1 class="sr-only">{{ client.hero.titleLine1 }} {{ client.hero.titleLine2 }}</h1>
  <button type="button" id="hero-video-toggle" aria-label="Pause video" class="absolute bottom-4 left-4 z-10 hidden items-center justify-center rounded-full bg-black/40 p-2.5 text-white backdrop-blur-sm transition hover:bg-black/60 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
    <svg data-icon="pause" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="size-5">
      <path d="M6.75 5.25h3v13.5h-3zM14.25 5.25h3v13.5h-3z" />
    </svg>
    <svg data-icon="play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="hidden size-5">
      <path d="M8 5.14v13.72a.75.75 0 0 0 1.13.65l11.13-6.86a.75.75 0 0 0 0-1.3L9.13 4.49A.75.75 0 0 0 8 5.14z" />
    </svg>
  </button>
</section>
