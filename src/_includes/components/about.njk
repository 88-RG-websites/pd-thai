<section id="story" class="relative flex min-h-[640px] items-center overflow-hidden bg-fixed bg-cover bg-center bg-no-repeat" style="background-image: url('{{ client.about_bg | htmlBaseUrl }}');">
  <div class="absolute inset-0 bg-[rgba(20,14,10,0.28)]"></div>

  <!-- Content container -->
  <div class="relative z-10 flex w-full justify-end px-7 py-16">
    <!-- White content box -->
    <div class="max-w-xl rounded-[4px] bg-white p-11 shadow-[0_30px_60px_-20px_rgba(0,0,0,0.4)]">
      <p class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.1em] text-primary-600">{{ client.about_kicker }}</p>
      <h2 class="text-balance mb-5 text-[26px] font-bold leading-[1.2] tracking-tight text-[#241b16] sm:text-4xl">{{ client.about_title }}</h2>
      <p class="mb-4 text-base leading-relaxed text-[#4a3d34]">{{ client.about_desc_one }}</p>
      {% if client.about_desc_two %}<p class="text-base leading-relaxed text-[#4a3d34]">{{ client.about_desc_two }}</p>{% endif %}
    </div>
  </div>
</section>
