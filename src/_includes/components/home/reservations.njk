      </div>
      <div class="flex justify-center" data-reveal="up">
        <iframe id="widget" title="Online reservation booking for {{ client.name }}" loading="lazy" width="300" height="442" src="https://88restaurants.com/pd-thai-austin-austin-tx/widgets/1" style="border:none;background:none;display:block;border-radius:5px"></iframe>
      </div>
    </div>
  </div>
</section>
