<div class="relative border-t border-black/10 bg-white md:absolute md:inset-x-0 md:bottom-0 md:z-10 md:border-white/15 md:bg-[#1a1410]/80 md:backdrop-blur-sm">
  <div class="mx-auto max-w-7xl px-6 py-6 md:py-3 lg:px-8">
    <div class="grid grid-cols-1 gap-6 divide-y divide-[#241b16]/10 md:divide-white/10 text-center sm:grid-cols-3 sm:gap-8 sm:divide-x sm:divide-y-0">
      <div class="flex flex-col items-center gap-1.5 sm:pr-8">
        <div class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.15em] text-primary-700 md:text-primary-200">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Address
        </div>
        <a class="text-[15px] text-[#4a3d34] hover:text-[#241b16] md:text-white/85 md:hover:text-white hover:underline" href="{{ client.googleMapsUrl }}" target="_blank" rel="noopener noreferrer">{{ client.address.street }}, {{ client.address.city }}, {{ client.address.state }}</a>
      </div>
      <div class="flex flex-col items-center gap-1.5 pt-6 sm:px-8 sm:pt-0">
        <div class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.15em] text-primary-700 md:text-primary-200">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Open Late
        </div>
        <p class="text-[15px] text-[#4a3d34] md:text-white/85">{{ client.hoursNote }}</p>
      </div>
      <div class="flex flex-col items-center gap-1.5 pt-6 sm:pl-8 sm:pt-0">
        <div class="flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.15em] text-primary-700 md:text-primary-200">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Phone
        </div>
        <a class="text-[15px] text-[#4a3d34] hover:text-[#241b16] md:text-white/85 md:hover:text-white hover:underline" href="tel:{{ client.phone }}">{{ client.phone }}</a>
      </div>
    </div>
  </div>
</div>
