<section id="story" class="bg-[#f7f1e6] py-24">
  <div class="mx-auto grid max-w-6xl items-center gap-14 px-7 lg:grid-cols-2">
    <div data-reveal="left">
      <p class="mb-3 text-sm font-bold uppercase tracking-[0.1em] text-primary-600">{{ client.about_kicker }}</p>
      <h2 class="text-balance mb-6 text-[34px] font-bold leading-[1.15] tracking-tight text-[#241b16] sm:text-5xl">{{ client.about_title }}</h2>
      <p class="mb-4 text-lg leading-relaxed text-[#4a3d34]">{{ client.about_desc_one }}</p>
      {% if client.about_desc_two %}<p class="text-lg leading-relaxed text-[#4a3d34]">{{ client.about_desc_two }}</p>{% endif %}
    </div>
    <div class="lg:-my-12 lg:-mr-10" data-reveal="right">
      <img src="/assets/images/plate-extra.webp" alt="Tom yum soup with fresh shrimp, herbs, and spices" class="mx-auto w-full max-w-lg lg:max-w-none lg:w-[640px] drop-shadow-[0_20px_35px_rgba(36,27,22,0.25)]" />
    </div>
  </div>
</section>
