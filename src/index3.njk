<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <script>
      document.documentElement.classList.add('js-reveal');
      // Safety net: if scroll-reveal.js never confirms it's watching the page
      // (blocked script, stale cache, ad blocker, etc.), stop hiding content
      // rather than leave the page permanently blank.
      window.addEventListener('load', function () {
        setTimeout(function () {
          if (!window.__scrollRevealReady) {
            document.documentElement.classList.remove('js-reveal');
          }
        }, 2000);
      });
    </script>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Real Thai flavor steps from UT Austin. Fresh, locally sourced ingredients, vegan & vegetarian options, and a colorful modern dining room on Guadalupe Street.">
    <meta name="robots" content="noindex">

    <link rel="stylesheet" href="/assets/css/styles.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;0,800;1,600&display=swap" rel="stylesheet">

    <title>PD Thai Cuisine - Authentic Thai Restaurant Near UT Austin</title>
  </head>

  <body>
    {% include "components/index3/logo-header.njk" %}
    <main>
      {% include "components/index3/hero.njk" %}
      {% include "components/index3/near-campus.njk" %}
      {% include "components/index3/order-online.njk" %}
      {% include "components/index3/reservations.njk" %}
      {% include "components/index3/catering-parties.njk" %}
    </main>
    {% include "components/index3/footer.njk" %}
    <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script>
    <script type="module" src="/assets/js/main.js"></script>
  </body>
</html>
