<section class="bg-white py-24">
  <div class="mx-auto max-w-6xl px-7">
    <div class="mx-auto mb-12 max-w-xl text-center">
      <p class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.1em] text-primary-600">{{ client.reviewsIntro.kicker }}</p>
      <h2 class="text-balance text-[28px] font-bold tracking-tight text-[#241b16] sm:text-4xl">{{ client.reviewsIntro.heading }}</h2>
    </div>

    <div class="relative">
      <div id="reviews-viewport" class="overflow-hidden">
        <div id="reviews-track" class="flex gap-[22px] transition-transform duration-500 ease-in-out">
          {% for review in client.reviews %}
          <div class="reviews-slide w-full shrink-0 sm:w-[calc((100%-44px)/3)]">
            <a href="{{ client.googlePlacesUrl }}" target="_blank" rel="noopener noreferrer" class="block h-full rounded-2xl border border-[#c1dabe] bg-[#e3eee2] p-7 transition hover:border-primary-400 hover:shadow-md" aria-label="Read {{ review.name }}'s review of {{ client.name }} on Google">
              <div class="mb-3.5 text-base tracking-[2px] text-[#e0a52a]">★★★★★</div>
              <p class="mb-[18px] text-[15px] leading-relaxed text-[#4a3d34]">&ldquo;{{ review.text }}&rdquo;</p>
              <div class="text-[13.5px] font-bold text-[#241b16]">{{ review.name }}</div>
              <div class="text-xs text-[#a08c78] underline decoration-[#e2d5c4] underline-offset-2">Google Review</div>
            </a>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <div id="reviews-dots" class="mt-8 flex justify-center gap-2"></div>
  </div>
</section>
