<section id="menu" class="bg-[#fdfaf5] py-24">
  <div class="mx-auto max-w-6xl px-7">
    <!-- Title Section -->
    <div class="mx-auto mb-14 max-w-xl text-center">
      <p class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.1em] text-primary-600">{{ client.menus.kicker }}</p>
      <h2 class="text-balance mb-4 text-[28px] font-bold tracking-tight text-[#241b16] sm:text-4xl">{{ client.menus.title }}</h2>
      {% if client.menus.subtitle %}
      <p class="text-[16.5px] leading-relaxed text-[#4a3d34]">{{ client.menus.subtitle }}</p>
      {% endif %}
    </div>

    <!-- Menu Cards Grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {% for card in client.menuCards %}
      <a
        href="{{ client.orderOnlineUrl }}"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative block h-[340px] overflow-hidden rounded-2xl shadow-[0_16px_32px_-16px_rgba(36,27,22,0.35)]"
        aria-label="View {{ card.title }} menu - {{ card.pretitle }}"
      >
        <img src="{{ card.image }}" alt="{{ card.title }}" class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
        <div class="absolute inset-0" style="background:linear-gradient(180deg, rgba(20,14,10,0.1) 30%, rgba(20,14,10,0.75) 100%);"></div>
        <div class="absolute inset-x-0 bottom-0 p-6 text-white">
          <div class="mb-1.5 text-xs font-semibold uppercase tracking-[0.1em] opacity-85">{{ card.pretitle }}</div>
          <div class="text-[23px] font-bold">{{ card.title }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

