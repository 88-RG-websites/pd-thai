---
title: "Catering - PD Thai Cuisine"
description: "Thai catering for birthdays, graduations, and office parties near UT Austin. Vegetarian, vegan, and gluten-free options available for pickup or delivery."
---
{% extends "layouts/base.njk" %}

{% block content %}
<section class="relative isolate overflow-hidden bg-[#fdfaf5] py-24">
  <img src="/assets/images/basil-leaf.webp" alt="" aria-hidden="true" class="pointer-events-none absolute -right-24 top-0 -z-10 w-[65vw] max-w-[760px] rotate-12 select-none opacity-[0.16]" />
  <div class="mx-auto max-w-3xl px-7">
    <div class="mb-14 text-center" data-reveal="up">
      <p class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.1em] text-primary-600">{{ client.catering.kicker }}</p>
      <h1 class="text-balance mb-6 text-[32px] font-bold tracking-tight text-[#241b16] sm:text-[40px]">{{ client.catering.heading }}</h1>
      <p class="mb-4 text-[16.5px] leading-relaxed text-[#4a3d34]">{{ client.catering.paragraphOne }}</p>
      <p class="text-[16.5px] leading-relaxed text-[#4a3d34]">{{ client.catering.paragraphTwo }}</p>
    </div>
    <div class="rounded-2xl border border-[#ece2d3] bg-white p-7 sm:p-10" data-reveal="up" data-reveal-delay="1">
      <p class="mb-6 text-center text-[15px] leading-relaxed text-[#4a3d34]">{{ client.catering.formNote }}</p>
      <iframe src="{{ client.catering.formUrl }}" frameborder="0" width="100%" height="700" style="min-height: 700px; overflow: hidden;" scrolling="no"></iframe>
    </div>
  </div>
</section>
{% endblock %}
