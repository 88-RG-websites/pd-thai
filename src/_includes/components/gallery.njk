<section id="gallery" class="bg-[#f7f1e6] py-24">
  <div class="mx-auto max-w-6xl px-7">
    <div class="mx-auto mb-12 max-w-xl text-center">
      <p class="mb-2.5 text-[13px] font-bold uppercase tracking-[0.1em] text-primary-600">{{ client.galleryIntro.kicker }}</p>
      <h2 class="text-balance text-[28px] font-bold tracking-tight text-[#241b16] sm:text-4xl">{{ client.galleryIntro.heading }}</h2>
    </div>

    <div itemtype="http://schema.org/ImageGallery" class="grid grid-cols-2 gap-3.5 itemscope sm:grid-cols-3 lg:grid-cols-4" id="gallery-grid">
      {% for img in client.galleryImages %}
      <figure itemprop="associatedMedia" itemscope itemtype="http://schema.org/ImageObject" class="group cursor-pointer">
        <div class="aspect-square overflow-hidden rounded-lg bg-gray-200">
          <img
            src="{{ img.thumb }}"
            itemprop="thumbnail"
            alt="{{ img.alt }}"
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            data-full-image="{{ img.full | htmlBaseUrl }}"
          >
        </div>
      </figure>
      {% endfor %}
    </div>
  </div>

  <!-- Image Modal -->
  <div id="gallery-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black bg-opacity-75 p-4 backdrop-blur-sm">
    <button
      id="modal-close"
      class="fixed right-4 top-4 z-50 flex size-10 items-center justify-center rounded-full bg-white bg-opacity-20 text-white transition-colors hover:bg-opacity-30"
      aria-label="Close gallery"
    >
      <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div class="relative flex h-full w-full max-w-4xl max-h-full items-center justify-center">
      <button
        id="modal-prev"
        class="absolute left-4 z-10 flex size-12 items-center justify-center rounded-full bg-white bg-opacity-20 text-white transition-colors hover:bg-opacity-30"
        aria-label="Previous image"
      >
        <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <button
        id="modal-next"
        class="absolute right-4 z-10 flex size-12 items-center justify-center rounded-full bg-white bg-opacity-20 text-white transition-colors hover:bg-opacity-30"
        aria-label="Next image"
      >
        <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>

      <div class="flex h-full w-full items-center justify-center">
        <img
          id="modal-image"
          class="max-h-full max-w-full rounded-lg object-contain shadow-2xl"
          alt=""
        >
      </div>

      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded-lg bg-black bg-opacity-50 px-4 py-2 text-white">
        <p id="modal-caption" class="text-sm font-medium"></p>
      </div>
    </div>
  </div>
</section>
