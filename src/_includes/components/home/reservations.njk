<section id="reservations" class="relative scroll-mt-24 overflow-hidden bg-[#241b16] bg-cover bg-center py-16 sm:bg-fixed md:py-[88px]" style="background-image:url({{ '/assets/images/reservations-bg.jpg' | htmlBaseUrl }})">
  <div class="absolute inset-0 bg-[#1a1410]/55"></div>
  <div class="relative z-10 mx-auto max-w-5xl px-3 sm:px-7 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-12 rounded-3xl border border-white/15 bg-[#1a1410]/65 px-4 py-8 backdrop-blur-sm sm:p-8 md:grid-cols-2 md:gap-14 md:p-14">
      <div data-reveal="up">
        <p class="mb-3 text-sm font-bold uppercase tracking-[0.1em] text-primary-300">Reserve Online</p>
