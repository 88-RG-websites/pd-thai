<section id="contact" class="bg-[#fdfaf5] py-24">
  <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-12 px-7 lg:grid-cols-2 lg:gap-16">
    <div class="text-[#241b16]">
      <h2 class="mb-7 text-[26px] font-bold tracking-tight sm:text-[34px]">{{ client.contact.heading }}</h2>

      <div class="mb-6 flex gap-3.5">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5f9c56" stroke-width="2" class="mt-0.5 flex-none"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <div>
          <div class="text-[15px] font-semibold">{{ client.address.street }}</div>
          <div class="text-[14.5px] text-[#6b5d50]">{{ client.address.city }}, {{ client.address.state }} {{ client.address.zip }}</div>
          <a href="{{ client.googleMapsUrl }}" target="_blank" rel="noopener noreferrer" class="mt-1.5 inline-block text-[13.5px] font-semibold text-primary-600 hover:text-primary-700">Get Directions →</a>
        </div>
      </div>

      <div class="mb-6 flex gap-3.5">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5f9c56" stroke-width="2" class="mt-0.5 flex-none"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <div>
          <div class="text-[15px] font-semibold">{{ client.phone }}</div>
          <div class="text-[14.5px] text-[#6b5d50]">{{ client.email }}</div>
        </div>
      </div>

      <div class="mb-8 flex gap-3.5">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5f9c56" stroke-width="2" class="mt-0.5 flex-none"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <div class="text-[14.5px] leading-relaxed text-[#6b5d50]">
          {{ client.hoursDisclaimer }}
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <button type="button" command="show-modal" commandfor="contact-modal" class="rounded-full bg-primary-500 px-[22px] py-[13px] text-[14.5px] font-semibold text-white hover:bg-primary-600">Get in Touch</button>
        <a href="tel:{{ client.phone }}" class="rounded-full border-[1.5px] border-primary-500 px-[21px] py-3 text-[14.5px] font-semibold text-primary-700 hover:bg-primary-50">Call Us</a>
      </div>
    </div>
    <div class="h-[420px] overflow-hidden rounded-2xl shadow-[0_20px_40px_-15px_rgba(36,27,22,0.3)]">
      <iframe title="{{ client.name }} location map" width="100%" height="100%" style="border:0; display:block;" loading="lazy" src="{{ client.googleMapsEmbedUrl }}"></iframe>
    </div>
  </div>

  <el-dialog>
    <dialog id="contact-modal" class="m-0 p-0 backdrop:bg-black/60">
      <div tabindex="0" class="fixed inset-0 z-50 flex items-center justify-center p-4 focus:outline-none">
        <el-dialog-panel class="relative w-full max-w-lg rounded-2xl bg-white p-7 shadow-2xl sm:p-9">
          <button type="button" command="close" commandfor="contact-modal" aria-label="Close" class="absolute right-4 top-4 flex size-9 items-center justify-center rounded-full text-[#6b5d50] hover:bg-[#f7f1e6]">
            <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <h3 class="mb-6 pr-8 text-center text-[22px] font-bold tracking-tight text-[#241b16]">{{ client.contact.formHeading }}</h3>
          <iframe src="{{ client.contact.formUrl }}" frameborder="0" width="100%" height="545" scrolling="no"></iframe>
        </el-dialog-panel>
      </div>
    </dialog>
  </el-dialog>
</section>
